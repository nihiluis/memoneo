# Docker Compose environment for backend/docker-compose.yml

DATA_DB_NAME=memoneo
DATA_DB_USER=memoneo
DATA_DB_PASSWORD=change-me

# Stable key id advertised in JWT headers and JWKS.
AUTH_KID=memoneo-auth
AUTH_JWT_ISSUER=memoneo-auth
AUTH_JWT_AUDIENCE=memoneo

# Base64-encoded RS256 private key PEM used by auth to sign JWTs.
# Generate one with:
# openssl genrsa 2048 | base64 | tr -d '\n'
AUTH_JWT_SIGNING_KEY="LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQo..."
