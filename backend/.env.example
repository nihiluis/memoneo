# Docker Compose environment for backend/docker-compose.yml

DATA_DB_NAME=memoneo
DATA_DB_USER=memoneo
DATA_DB_PASSWORD=change-me

# Stable key id advertised in JWT headers and JWKS.
AUTH_KID=memoneo-auth

# RS256 private key used by auth to sign JWTs.
# Generate one with:
# openssl genrsa 2048 | awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}'
AUTH_JWT_SIGNING_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
