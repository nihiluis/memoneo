{
  "compilerOptions": {
    "declaration": true,
    "module": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "target": "es2022",
    "types": ["bun-types"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "NodeNext"
  },
  "include": ["./src/**/*"],
  "ts-node": {
    "esm": true
  }
}
